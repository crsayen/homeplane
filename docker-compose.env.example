# Hostnames served by Caddy (comma-separated for multiple).
# Add these hostnames to your LAN DNS or /etc/hosts pointing to your server IP.
HOMEPLANE_HOSTS=homeplane.lan

# API URL used by the built frontend. Leave empty to use current origin (recommended).
VITE_HOMEPLANE_API_URL=

# Shared key sent by frontend in x-homeplane-key (must match backend APP_API_KEY)
VITE_HOMEPLANE_API_KEY=replace-with-your-app-api-key
