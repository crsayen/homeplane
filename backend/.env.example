# Home Assistant base URL. Example: http://homeassistant.local:8123
HA_BASE_URL=http://homeassistant.local:8123
# Long-lived access token generated in Home Assistant
HA_TOKEN=replace-with-home-assistant-token

# Shared API key that your React app sends in x-homeplane-key
APP_API_KEY=replace-with-a-random-long-string

# CORS allow-list for frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional regex for dynamic local dev/LAN origins (for example Vite changing ports)
# ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|192\\.168\\.\\d+\\.\\d+)(:\\d+)?$

# In-memory rate limit (per API key + route)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# File path for persisted dashboard room configuration
AUDIO_CONFIG_PATH=./data/multi-room-audio.config.json
AUDIO_CONFIG_SEED_PATH=./data/multi-room-audio.config.json

# File path for persisted lighting dashboard configuration
LIGHTING_CONFIG_PATH=./data/lighting.config.json
LIGHTING_CONFIG_SEED_PATH=./data/lighting.config.json
